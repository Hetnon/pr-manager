# Three files, one for each scope. All are .gitignored.
#
#   .env.shared  → values identical in dev and prod (loaded in both)
#   .env.dev     → dev-only values (loaded in dev)
#   .env.prod    → prod-only values (uploaded to Secret Manager as env_secrets;
#                  loaded automatically in prod via loadSecrets())
#
# Server precedence on key collisions: .env.dev wins over .env.shared (dotenv
# keeps the first value it sees). Initial values are written by
# scripts/gcp-bootstrap.js.

# ─── .env.shared ────────────────────────────────────────────────────────────
# Same in dev and prod.
GOOGLE_PROJECT_ID=your-gcp-project-id
KMS_KEY_NAME=projects/your-gcp-project-id/locations/global/keyRings/pr-matrix-keys/cryptoKeys/tokens
GITHUB_OAUTH_SCOPES=repo read:user user:email

# ─── .env.dev ───────────────────────────────────────────────────────────────
NODE_ENV=development
SESSION_SECRET=replace-with-48+-bytes-of-random
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REDIRECT_URI=https://localhost:3030/api/auth/github/callback
POST_LOGIN_REDIRECT=https://localhost:3000/
COOKIE_DOMAIN=localhost
ALLOWED_ORIGINS=https://localhost:3000
GOOGLE_CLOUD_PROJECT=demo-project
FIRESTORE_EMULATOR_HOST=localhost:8080
PORT=3030

# ─── .env.prod ──────────────────────────────────────────────────────────────
# Different OAuth App for prod; callback / origin / cookie domain are the live
# App Engine hostnames.
SESSION_SECRET=replace-with-48+-bytes-of-random-DIFFERENT-FROM-DEV
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REDIRECT_URI=https://api-dot-<project>.<region>.r.appspot.com/api/auth/github/callback
POST_LOGIN_REDIRECT=https://<project>.<region>.r.appspot.com/
COOKIE_DOMAIN=<project>.<region>.r.appspot.com
ALLOWED_ORIGINS=https://<project>.<region>.r.appspot.com,https://api-dot-<project>.<region>.r.appspot.com
