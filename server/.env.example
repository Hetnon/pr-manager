# Copy to .env for local dev. Real values are written automatically by
# scripts/gcp-bootstrap.js — this file just documents the surface.
#
# .env is .gitignored. NEVER commit a populated copy.

# ─── Environment ────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Session / cookies ──────────────────────────────────────────────────────
# Used for: session cookie signing, OAuth-state HMAC.
SESSION_SECRET=replace-with-48+-bytes-of-random
COOKIE_DOMAIN=localhost

# ─── CORS / hosts ───────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://localhost:3000
PORT=3030

# ─── Firestore ──────────────────────────────────────────────────────────────
# Dev: point at the local emulator. The runFirebase.js script spawns it.
GOOGLE_CLOUD_PROJECT=demo-project
FIRESTORE_EMULATOR_HOST=localhost:8080
# Prod loadSecrets() uses this to find env_secrets in Secret Manager.
GOOGLE_PROJECT_ID=your-gcp-project-id

# ─── KMS (envelope encryption for stored OAuth tokens) ──────────────────────
# Real GCP key — even in dev. Your local gcloud auth needs
# roles/cloudkms.cryptoKeyEncrypterDecrypter on it (gcp-bootstrap grants this).
KMS_KEY_NAME=projects/your-gcp-project-id/locations/global/keyRings/pr-matrix-keys/cryptoKeys/tokens

# ─── GitHub OAuth App ───────────────────────────────────────────────────────
# Create at https://github.com/settings/developers
# Authorization callback URL must include the dev URL below.
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REDIRECT_URI=https://localhost:3030/api/auth/github/callback
GITHUB_OAUTH_SCOPES=repo read:user user:email
POST_LOGIN_REDIRECT=https://localhost:3000/
