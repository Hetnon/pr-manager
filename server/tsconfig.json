{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../TypesAndInterfaces/*", "./TypesAndInterfaces/*"]
    }
  },
  "include": [
    "server.ts",
    "config.ts",
    "databases/**/*.ts",
    "expressSession/**/*.ts",
    "infrastructure/**/*.ts",
    "routes/**/*.ts",
    "types/**/*.ts",
    "utils/**/*.ts",
    "validation_middleware/**/*.ts",
    "../TypesAndInterfaces/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts"
  ]
}
