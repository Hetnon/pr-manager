{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "checkJs": false,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../TypesAndInterfaces/*"]
    }
  },
  "include": [
